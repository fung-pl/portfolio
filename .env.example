# Gemini API Key
GEMINI_API_KEY=

# Resend API Key (for contact form)
# Get one for free at https://resend.com
RESEND_API_KEY=

# Vercel KV or Standard Redis - Persistence for views/citations
# OPTION 1: Single URL (Recommended if you only have one URL)
KV_URL=
# OR
KV_REDIS_URL=

# OPTION 2: Vercel KV REST API (Used by @vercel/kv)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=